{
  "name": "@qzr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply qzr-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply qzr-db --remote"
  },
  "dependencies": {
    "@qzr/shared": "workspace:*",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "~5.9.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
